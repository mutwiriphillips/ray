# For a split deployment (frontend on Vercel/Netlify/etc., backend on Render/etc.),
# set this to the backend's full public URL, e.g. https://skywalkers-backend.onrender.com
#
# For a combined deployment on Vercel (frontend + /api serverless functions in the
# SAME project — see "Deploying to Vercel" in the README), set this to an empty
# string instead, so the app calls same-origin relative paths like /api/consultations:
# VITE_API_URL=
VITE_API_URL=http://localhost:4000
